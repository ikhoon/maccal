#!/usr/bin/env bash
# mock `maccal` for the README demo gif — canned, fictional output that never
# touches a real calendar. Colors mirror the real CLI (time cyan, id dim,
# rw green / ro yellow, a truecolor swatch), so the gif shows the real look.
CY=$'\e[36m'; DIM=$'\e[2m'; GRN=$'\e[32m'; YEL=$'\e[33m'; BLD=$'\e[1m'; R=$'\e[0m'
sub="${1:-}"; shift 2>/dev/null || true
case "$sub" in
  calendars)
    printf "${BLD}%-12s${R} ${DIM}%-18s${R} ${DIM}%-13s${R} ${GRN}rw${R}  \e[38;2;255;204;0m●${R} %s\n" "Work" "you@example.com" "caldav" "#FFCC00"
    printf "${BLD}%-12s${R} ${DIM}%-18s${R} ${DIM}%-13s${R} ${GRN}rw${R}  \e[38;2;131;215;84m●${R} %s\n" "Personal" "you@example.com" "caldav" "#83D754"
    printf "${BLD}%-12s${R} ${DIM}%-18s${R} ${DIM}%-13s${R} ${YEL}ro${R}  \e[38;2;22;167;101m●${R} %s\n" "Holidays" "Subscriptions" "subscription" "#16A765"
    ;;
  agenda)
    printf "${CY}%-27s${R} %-15s ${DIM}%s${R}\n" "2026-06-23T10:30:00+09:00" "Standup" "1A2B…/RID"
    printf "${CY}%-27s${R} %-15s ${DIM}%s${R}\n" "2026-06-23T14:00:00+09:00" "Design review" "1A2B…@example.com"
    printf "${CY}%-27s${R} %-15s ${DIM}%s${R}\n" "2026-06-23T17:00:00+09:00" "1:1 with Sam" "1A2B…@example.com"
    ;;
  search)
    printf "${CY}%-27s${R} %-15s ${DIM}%s${R}\n" "2026-06-23T10:30:00+09:00" "Standup" "1A2B…/RID"
    printf "${CY}%-27s${R} %-15s ${DIM}%s${R}\n" "2026-06-16T10:30:00+09:00" "Standup" "9F3C…/RID"
    printf "total: 2\n"
    ;;
  add)
    printf "${DIM}%-14s${R}%s\n" "Title:" "Lunch"
    printf "${DIM}%-14s${R}%s\n" "When:" "2026-06-24T12:00:00+09:00 — 2026-06-24T13:00:00+09:00"
    printf "${DIM}%-14s${R}%s\n" "Calendar:" "Personal"
    printf "${DIM}%-14s${R}%s\n" "Status:" "confirmed"
    printf "${DIM}%-14s${R}%s\n" "Availability:" "busy"
    ;;
  *) printf 'maccal %s\n' "$sub" ;;
esac
